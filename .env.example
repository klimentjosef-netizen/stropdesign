# Email služba pro kontaktní formulář
# Zaregistrujte se na https://resend.com a získejte API klíč
RESEND_API_KEY=

# Kam se mají posílat poptávky (default: info@stropdesign.cz)
CONTACT_EMAIL=info@stropdesign.cz

# AI chatbot "Strop kecka"
# Získejte API klíč na https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Analytics 4 — formát G-XXXXXXXXXX (Admin → Data Streams → Web)
NEXT_PUBLIC_GA_ID=

# Google Ads — formát AW-XXXXXXXXX (Tools → Conversions → tag setup)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads conversion label — část za lomítkem v send_to, např. abcDEF123
# (Tools → Conversions → vytvořit konverzi "Odeslání kontaktního formuláře")
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# Sklik (Seznam) — retargetingId a conversionId od analytika klienta
NEXT_PUBLIC_SKLIK_RETARGETING_ID=
NEXT_PUBLIC_SKLIK_CONVERSION_ID=
