# Email služba pro kontaktní formulář
# Zaregistrujte se na https://resend.com a získejte API klíč
RESEND_API_KEY=

# Kam se mají posílat poptávky (default: info@stropdesign.cz)
CONTACT_EMAIL=info@stropdesign.cz

# Google Reviews — živé recenze z Google Maps
# 1. Vytvořte projekt na https://console.cloud.google.com
# 2. Zapněte Places API
# 3. Vytvořte API klíč (omezte na Places API + doménu stropdesign.cz)
GOOGLE_PLACES_API_KEY=

# Place ID pro StropDesign
# Najděte ho na: https://developers.google.com/maps/documentation/places/web-service/place-id-finder
# Vyhledejte "StropDesign" nebo "Derbau s.r.o. Ostrava"
GOOGLE_PLACE_ID=
